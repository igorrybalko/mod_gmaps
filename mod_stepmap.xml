<?xml version="1.0" encoding="utf-8"?>
<extension
    type="module" client="site" method="upgrade">
    <name>StepMap</name>
    <author>Ihor Rybalko</author>
    <creationDate>June 2019</creationDate>
    <license>GNU General Public License</license>
    <authorEmail>igorryb@proton.me</authorEmail>
    <authorUrl>webstep.top</authorUrl>
    <version>2.0.2</version>
    <description>Module Google Maps. Developed by https://webstep.top</description>
    <namespace path="src">Webstep\Module\Stepmap</namespace>
    <files>
        <folder module="mod_stepmap">services</folder>
        <folder>src</folder>
        <filename>mod_stepmap.xml</filename>
        <filename>index.html</filename>
        <folder>tmpl</folder>
        <folder>language</folder>
        <folder>media</folder>
    </files>
    <media destination="mod_stepmap" folder="media">
        <filename>joomla.asset.json</filename>
        <folder>js</folder>
    </media>
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field
                    name="lat_cent"
                    type="number" rows="3"
                    label="MOD_STEPMAP_LATITUDECENTER"
                    description="MOD_STEPMAP_NUMBERS" />
                <field
                    name="lng_cent"
                    type="number" rows="3"
                    label="MOD_STEPMAP_LONGCENTER"
                    description="MOD_STEPMAP_NUMBERS" />
                <field
                    name="zoom"
                    type="number" rows="3"
                    label="MOD_STEPMAP_SCALE"
                    description="MOD_STEPMAP_NUMBERS" />
                <field
                    name="height"
                    type="number" rows="3"
                    label="MOD_STEPMAP_HEIGHT"
                    description="MOD_STEPMAP_PIXELS" />
                <field
                    name="key"
                    type="text" rows="3"
                    label="API Key"
                    description="Google Maps JavaScript API Key" />

                <field
                    type="subform"
                    name="items"
                    label="MOD_STEPMAP_DATA"
                    multiple="true"
                    layout="joomla.form.field.subform.repeatable-table">
                    
                    <form>
                        <field
                            name="lat"
                            type="number" rows="3"
                            label="MOD_STEPMAP_LATITUDE"
                            description="MOD_STEPMAP_NUMBERS" />
                        <field
                            name="lng"
                            type="number" rows="3"
                            label="MOD_STEPMAP_LONGITUDE"
                            description="MOD_STEPMAP_NUMBERS" />
                        <field
                            name="desc"
                            type="text" rows="3"
                            label="MOD_STEPMAP_DESC"
                            description="MOD_STEPMAP_DETAL" />
                    </form>
                </field>

            </fieldset>
            <fieldset name="advanced">
				<field
                    name="layout"
                    type="modulelayout"
                    class="form-select"
                    label="JFIELD_ALT_LAYOUT_LABEL"
                    description="JFIELD_ALT_MODULE_LAYOUT_DESC" />
                <field
                    name="moduleclass_sfx"
                    type="text"
                    label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
                    description="COM_MODULES_FIELD_MODULECLASS_SFX_DESC" />
            </fieldset>
        </fields>
    </config>
    <updateservers>
        <server 
            type="extension" 
            priority="1" 
            name="stepmap">
            https://raw.githubusercontent.com/igorrybalko/mod_stepmap/main/update.xml
        </server>
    </updateservers>
</extension>