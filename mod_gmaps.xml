<?xml version="1.0" encoding="utf-8"?>
<extension
    type="module" client="site" method="upgrade">
    <name>GMaps module</name>
    <author>Ihor Rybalko</author>
    <creationDate>June 2019</creationDate>
    <license>GNU General Public License</license>
    <authorEmail>igorryb@proton.me</authorEmail>
    <authorUrl>webstep.top</authorUrl>
    <version>2.0.0</version>
    <description>Module Google Maps. Developed by https://webstep.top</description>
    <namespace path="src">Webstep\Module\Gmaps</namespace>
    <files>
        <folder module="mod_gmaps">services</folder>
        <folder>src</folder>
        <filename>mod_gmaps.xml</filename>
        <filename>index.html</filename>
        <folder>tmpl</folder>
        <folder>language</folder>
        <folder>media</folder>
    </files>
    <media destination="mod_gmaps" folder="media">
        <folder>js</folder>
    </media>
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field
                    name="lat_cent"
                    type="number" rows="3"
                    label="MOD_GMAPS_LATITUDECENTER"
                    description="MOD_GMAPS_NUMBERS" />
                <field
                    name="lng_cent"
                    type="number" rows="3"
                    label="MOD_GMAPS_LONGCENTER"
                    description="MOD_GMAPS_NUMBERS" />
                <field
                    name="zoom"
                    type="number" rows="3"
                    label="MOD_GMAPS_SCALE"
                    description="MOD_GMAPS_INTEGER" />
                <field
                    name="height"
                    type="number" rows="3"
                    label="MOD_GMAPS_HEIGHT"
                    description="MOD_GMAPS_PIXELS" />
                <field
                    name="key"
                    type="text" rows="3"
                    label="API Key"
                    description="Google Maps JavaScript API" />

                <field
                    type="subform"
                    name="items"
                    label="MOD_GMAPS_DATA"
                    multiple="true"
                    layout="joomla.form.field.subform.repeatable-table">
                    
                    <form>
                        <field
                            name="lat"
                            type="number" rows="3"
                            label="MOD_GMAPS_LATITUDE"
                            description="MOD_GMAPS_NUMBERS" />
                        <field
                            name="lng"
                            type="number" rows="3"
                            label="MOD_GMAPS_LONGITUDE"
                            description="MOD_GMAPS_NUMBERS" />
                        <field
                            name="desc"
                            type="text" rows="3"
                            label="MOD_GMAPS_DESC"
                            description="MOD_GMAPS_DETAL" />
                    </form>
                </field>

            </fieldset>
            <fieldset name="advanced">
				<field
                    name="layout"
                    type="modulelayout"
                    class="form-select"
                    label="JFIELD_ALT_LAYOUT_LABEL"
                    description="JFIELD_ALT_MODULE_LAYOUT_DESC" />
                <field
                    name="moduleclass_sfx"
                    type="text"
                    label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
                    description="COM_MODULES_FIELD_MODULECLASS_SFX_DESC" />
            </fieldset>
        </fields>
    </config>
</extension>